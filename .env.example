# 安全智能审核系统环境变量配置
# 复制此文件为 .env 并填写实际值
# 注意：不要将此文件提交到版本控制系统

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 数据库配置（可选）
# DATABASE_URL=sqlite:///data/safety_audit.db

# 服务器配置（可选）
# HOST=0.0.0.0
# PORT=8000

# 日志级别（可选）
# LOG_LEVEL=INFO

# 安全配置（可选）
# SECRET_KEY=your_secret_key_for_sessions
# SESSION_TIMEOUT=3600